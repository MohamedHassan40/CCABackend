# Database (required)
DATABASE_URL=postgresql://postgres:password@localhost:5432/cloud_org?schema=public

# Auth (required – min 32 chars for JWT_SECRET)
JWT_SECRET=your-very-secret-key-min-32-characters-long
JWT_EXPIRES_IN=7d

# Server
PORT=3001
NODE_ENV=development

# URLs & CORS (for frontend / production)
# Browsers require the deployed frontend origin here or requests fail with CORS errors.
# Use HTTPS + exact host (no trailing slash). Multiple origins: comma-separated.
# Example: CORS_ORIGIN=https://cca-frontend-green.vercel.app,http://localhost:3000
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3000

# Optional: Email — use either SMTP (Gmail / Google Workspace app password) or SendGrid
#
# SMTP / Gmail example (TLS on 587):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=youraccount@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="CCA Org <youraccount@gmail.com>"
#
# SendGrid (if SMTP_* not set):
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=info@your-verified-domain.com
# SENDGRID_FROM_NAME=CCA System

# Optional: Payments (Moyasar) — see docs/moyasar-setup.md
# MOYASAR_SECRET_KEY=sk_test_...   # required for invoices / webhooks
# MOYASAR_PUBLISHABLE_KEY=pk_test_...  # optional unless embedding Moyasar.js on the client
# MOYASAR_WEBHOOK_SECRET=
# MOYASAR_CHECKOUT_METHODS=creditcard
# MOYASAR_SUPPORTED_NETWORKS=mada,visa,mastercard
# MOYASAR_APPLY_COUPON=false

# Optional: Sentry
# SENTRY_DSN=

# Optional: Redis
# REDIS_URL=redis://localhost:6379

# Optional: Storage (local | s3 | gcs | cloudinary)
# STORAGE_TYPE=local
# UPLOAD_DIR=./uploads

# Production org seed (run: SEED_PRODUCTION_ORG=true npm run prisma:seed:production)
# Base seed must be run first (npm run prisma:seed). In production, set a strong SEED_ORG_ADMIN_PASSWORD.
# SEED_PRODUCTION_ORG=true
# SEED_ORG_SLUG=production-demo
# SEED_ORG_NAME=Production Demo
# SEED_ORG_ADMIN_EMAIL=owner@production-demo.com
# SEED_ORG_ADMIN_PASSWORD=
